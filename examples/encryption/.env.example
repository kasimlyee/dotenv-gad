# Copy this file to .env and fill in real values, then follow the steps below.
#
# Step 1 — generate keys (run once):
#   npx dotenv-gad keygen
#   This writes ENVGAD_PUBLIC_KEY here and creates .env.keys (gitignored).
#
# Step 2 — fill in your plaintext secrets:
#   DATABASE_URL=postgresql://user:password@localhost:5432/mydb
#   API_SECRET=your-real-secret-here
#
# Step 3 — encrypt in-place:
#   npx dotenv-gad encrypt
#   Plaintext values become encrypted:v1:<base64> tokens safe to commit.
#
# Step 4 — run:
#   node index.js
#   dotenv-gad decrypts transparently at startup using .env.keys.

PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
API_SECRET=your-real-secret-here
